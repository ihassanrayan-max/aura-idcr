# AURA-IDCR - copy to `.env` when local config or prototype secrets are needed.
#
# The counterfactual advisor works without these values by falling back to a
# deterministic branch-comparison brief. Supplying an OpenAI key enables the
# optional LLM summary layer.
#
# These values are server-side only. Do not put the OpenAI key in a browser-
# exposed `VITE_*` variable.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
COUNTERFACTUAL_ADVISOR_RATE_LIMIT_MAX_REQUESTS=8
COUNTERFACTUAL_ADVISOR_RATE_LIMIT_WINDOW_MS=60000
